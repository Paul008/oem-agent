{
  // Multi-OEM AI Agent — OpenClaw on Moltworker
  // Docs: https://developers.cloudflare.com/workers/wrangler/configuration/

  "name": "oem-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-11",
  "compatibility_flags": ["nodejs_compat"],

  // R2 Storage (agent memory + OEM assets)
  "r2_buckets": [
    {
      "binding": "MOLTBOT_BUCKET",
      "bucket_name": "oem-agent-assets"
    }
  ],

  // Browser Rendering (headless Chromium via CDP)
  "browser": {
    "binding": "BROWSER"
  },

  // AI Gateway (observability proxy)
  "ai": {
    "binding": "AI"
  },

  // Vectorize (UX knowledge base for semantic retrieval)
  "vectorize": [
    {
      "binding": "UX_KNOWLEDGE",
      "index_name": "ux-knowledge-base"
    }
  ],

  // Cloudflare Containers (Sandbox for code execution)
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "standard-1",
      "max_instances": 10
    }
  ],

  // Cloudflare Sandbox (Durable Object binding)
  "durable_objects": {
    "bindings": [
      {
        "name": "Sandbox",
        "class_name": "Sandbox"
      }
    ]
  },

  // Migrations for Durable Objects with Containers (requires new_sqlite_classes)
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Sandbox"]
    }
  ],

  // Environment Variables
  "vars": {
    "ENVIRONMENT": "production",
    "SANDBOX_SLEEP_AFTER": "never",
    "DEV_MODE": "true",
    "OPENCLAW_DEV_MODE": "true",
    "R2_BUCKET_NAME": "oem-agent-assets",
    "CF_ACCOUNT_ID": "a5b299b3ad15c1b5b895dc66f9357b17",
    // Optional: Lightpanda WebSocket URL for headless browser rendering.
    // When not set, falls back to Cloudflare Browser (env.BROWSER binding).
    "LIGHTPANDA_URL": ""
  },

  // Secrets (set via `wrangler secret put`):
  // SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ACCESS_TOKEN, SUPABASE_DB_PASSWORD
  // GROQ_API_KEY, TOGETHER_API_KEY, ANTHROPIC_API_KEY, GEMINI_API_KEY, PERPLEXITY_API_KEY
  // RESEND_API_KEY
  // SLACK_WEBHOOK_URL, SLACK_BOT_TOKEN, SLACK_SIGNING_SECRET
  // BRAVE_SEARCH_API_KEY
  // CLOUDFLARE_ACCOUNT_ID
  // CDP_SECRET

  // Cron Triggers (crawl schedules)
  "triggers": {
    "crons": [
      "0 */2 * * *",
      "0 5 * * *",
      "0 */12 * * *",
      "0 6 * * *",
      "0 7 * * *"
    ]
  },

  // Dev environment
  "env": {
    "dev": {
      "name": "oem-agent-dev",
      "vars": {
        "ENVIRONMENT": "development",
        "SANDBOX_SLEEP_AFTER": "never",
        "DEV_MODE": "true",
        "OPENCLAW_DEV_MODE": "true",
        "R2_BUCKET_NAME": "oem-agent-assets-dev",
        "CF_ACCOUNT_ID": "a5b299b3ad15c1b5b895dc66f9357b17",
        // Optional: Lightpanda WebSocket URL (falls back to Cloudflare Browser)
        "LIGHTPANDA_URL": ""
      },
      "r2_buckets": [
        {
          "binding": "MOLTBOT_BUCKET",
          "bucket_name": "oem-agent-assets-dev"
        }
      ],
      "browser": {
        "binding": "BROWSER"
      },
      "ai": {
        "binding": "AI"
      },
      "vectorize": [
        {
          "binding": "UX_KNOWLEDGE",
          "index_name": "ux-knowledge-base"
        }
      ],
      "containers": [
        {
          "class_name": "Sandbox",
          "image": "./Dockerfile",
          "instance_type": "standard-1",
          "max_instances": 10
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "Sandbox",
            "class_name": "Sandbox"
          }
        ]
      }
    }
  }
}
